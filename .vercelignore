# Xcode build artifacts (ne JAMAIS uploader sur Vercel — peuvent atteindre
# 300MB+ de XCFrameworks SPM + ModuleCache, et n'ont rien à faire en prod web).
build/sim/
ios/App/build/
ios/App/Pods/
*.xcarchive
*.ipa
*.dSYM
DerivedData/

# Android build artifacts (capacitor sync génère le dossier, jamais utile en
# prod web). Cause des erreurs lstat sur des fichiers manifest absents.
android/

# Misc
.DS_Store
*.log
