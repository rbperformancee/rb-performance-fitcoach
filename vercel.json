{
  "buildCommand": "react-scripts build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron-relance",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron-weekly-recap",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron-coach-weekly-digest",
      "schedule": "0 7 * * 1"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "rbperform.app" }],
      "destination": "/landing.html"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.rbperform.app" }],
      "destination": "/landing.html"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "rb-perfor.vercel.app" }],
      "destination": "/landing.html"
    },
    { "source": "/rejoindre/:slug", "destination": "/?coach=:slug" },
    { "source": "/founding",    "destination": "/founding.html" },
    { "source": "/link",        "destination": "/link.html" },
    { "source": "/waitlist",    "destination": "/waitlist.html" },
    { "source": "/demo",        "destination": "/?demo=true" },
    { "source": "/demo-client", "destination": "/?demo-client=true" },
    { "source": "/login",       "destination": "/index.html" },
    { "source": "/signup",      "destination": "/index.html" },
    { "source": "/join",        "destination": "/index.html" },
    { "source": "/coach/:slug", "destination": "/coach.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self), geolocation=(), payment=(self)" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co; frame-ancestors 'self'" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/landing.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/founding.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/static/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.webp",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/landing-style.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/landing-script.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/:path*.woff2",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
