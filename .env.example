# ===== Supabase =====
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=sb_publishable_xxx

# ===== Sandbox demo (route /demo, live preview landing) =====
# Compte coach fictif pour permettre aux visiteurs landing d'explorer
# le dashboard sans creer de compte. 8 clients fictifs avec donnees demo.
# Auto-login lors de la visite de /demo. Banner teal en haut + timer 15min.
REACT_APP_DEMO_EMAIL=demo@rbperform.app
REACT_APP_DEMO_PASSWORD=xxx
REACT_APP_DEMO_COACH_ID=33ae97b9-b068-44f3-bef0-0c7c18e5b774

# ===== Sandbox demo CLIENT (route /demo-client) =====
# Compte client fictif "Lucas Bernard" rattache au coach demo.
# Auto-login via /api/demo-client (OTP serverless — zero mot de passe).
# Le compte est cree via supabase admin API (email_confirm: true).
# Aucune variable REACT_APP_DEMO_CLIENT_PASSWORD necessaire.
# La session est generee cote serveur avec SUPABASE_SERVICE_ROLE_KEY.
# Cote Vercel, s'assurer que SUPABASE_ANON_KEY est set (ou REACT_APP_SUPABASE_ANON_KEY).

# ===== Stripe (serveur — Vercel env vars, pas dans .env frontend) =====
# Dashboard -> Developers -> API keys
# sk_live_... en production, sk_test_... en preview/dev
# STRIPE_SECRET_KEY=sk_live_xxx
#
# Dashboard -> Developers -> Webhooks -> (endpoint /api/webhook-stripe) -> Signing secret
# STRIPE_WEBHOOK_SECRET=whsec_xxx
#
# Cle publique cote client (optionnelle — utilisee seulement si un composant
# fait directement du Stripe.js ; actuellement tout passe par Payment Links
# + /api/billing-portal donc non requise)
# REACT_APP_STRIPE_PUBLIC_KEY=pk_live_xxx
#
# Price IDs — requis uniquement si /api/checkout ou /api/checkout-founding
# sont reactives (actuellement la landing pointe vers des Payment Links
# directs, donc ces vars sont optionnelles) :
# STRIPE_PRICE_STARTER=price_xxx    # 199EUR/mois
# STRIPE_PRICE_PRO=price_xxx        # 299EUR/mois
# STRIPE_PRICE_ELITE=price_xxx      # 499EUR/mois
# STRIPE_PRICE_FOUNDING=price_xxx   # 199EUR/mois x 12 mois (Founder)
# STRIPE_PRICE_FOUNDING_USD=price_xxx # 229USD/mois (optionnel)
# STRIPE_PRICE_FOUNDING_GBP=price_xxx # 179GBP/mois (optionnel)

# ===== Sentry (optionnel — error tracking en prod) =====
# REACT_APP_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# REACT_APP_RELEASE=rb-perform@1.0

# ===== VAPID push notifications =====
# Generer une paire de cles : npx web-push generate-vapid-keys
# La cle publique va dans le frontend (ici), la privee dans les
# secrets Supabase Edge Functions (VAPID_PRIVATE_KEY).
# Sans cles, les push notifications ne fonctionnent pas (les events
# 'push' du sw.js ne se declenchent jamais).
REACT_APP_VAPID_PUBLIC_KEY=BB...
# Cote serveur (Supabase secrets), pas dans .env frontend:
#   VAPID_PRIVATE_KEY=...
#   VAPID_SUBJECT=mailto:rb.performancee@gmail.com

# ===== Sentinel — agent IA business =====
REACT_APP_SENTINEL_ENABLED=true
# MISTRAL_API_KEY=xxx (cote serveur Vercel uniquement)
# MISTRAL_DAILY_BUDGET_USD=50 (cap quotidien, cote serveur)

# ===== Cote serveur (Vercel env vars, pas dans .env frontend) =====
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx (deja set pour les crons)
# SUPABASE_ANON_KEY=sb_publishable_xxx (utilise par /api/demo-client pour
#   echanger le OTP contre une session. Fallback: REACT_APP_SUPABASE_ANON_KEY)
# CRON_SECRET=$(openssl rand -hex 32)
