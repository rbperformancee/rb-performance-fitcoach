{
  "buildCommand": "react-scripts build && cp build/index.html build/app.html && cp public/landing.html build/index.html",
  "outputDirectory": "build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron-relance",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron-weekly-recap",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron-coach-weekly-digest",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/sentinel-benchmarks",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/sentinel-daily",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron/sentinel-weekly",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/cold-outreach",
      "schedule": "0 8 * * *"
    }
  ],
  "rewrites": [
    { "source": "/rejoindre/:slug", "destination": "/app.html?coach=:slug" },
    { "source": "/founding",    "destination": "/founding.html" },
    { "source": "/link",        "destination": "/link.html" },
    { "source": "/waitlist",    "destination": "/waitlist.html" },
    { "source": "/demo",        "destination": "/app.html?demo=true" },
    { "source": "/demo-client", "destination": "/app.html?demo-client=true" },
    { "source": "/login",       "destination": "/app.html" },
    { "source": "/signup",      "destination": "/app.html" },
    { "source": "/join",        "destination": "/app.html" },
    { "source": "/dashboard/mon-compte", "destination": "/app.html?view=mon-compte&tab=abonnement" },
    { "source": "/status", "destination": "/status.html" },
    { "source": "/coach/:slug", "destination": "/coach.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self), geolocation=(), payment=(self)" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.sentry.io; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; object-src 'none'" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/landing.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/founding.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/static/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.webp",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/landing-style.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/landing-script.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/:path*.woff2",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/videos/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
